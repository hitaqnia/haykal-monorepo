{
    "name": "hitaqnia/haykal-monorepo",
    "description": "Hitaqnia Laravel boilerplate package suite (monorepo).",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "hitaqnia/haykal-core": "@dev",
        "hitaqnia/haykal-api": "@dev",
        "hitaqnia/haykal-filament": "@dev",
        "hitaqnia/haykal": "@dev",
        "hitaqnia/filament-mapbox": "@dev",
        "hitaqnia/filament-viewerjs": "@dev"
    },
    "require-dev": {
        "laravel/pint": "^1.23",
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Hitaqnia\\Haykal\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/haykal-core",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "packages/haykal-api",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "packages/haykal-filament",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "packages/haykal",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "packages/filament-mapbox",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "packages/filament-viewerjs",
            "options": { "symlink": true }
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "format": "pint",
        "format:check": "pint --test"
    }
}
