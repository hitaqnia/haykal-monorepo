{
    "name": "hitaqnia/haykal-monorepo",
    "description": "HiTaqnia Laravel boilerplate package suite (monorepo).",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "hitaqnia/haykal-core": "^1.0",
        "hitaqnia/haykal-api": "^1.0",
        "hitaqnia/haykal-filament": "^1.0",
        "hitaqnia/haykal": "^1.0"
    },
    "require-dev": {
        "laravel/pint": "^1.23",
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload-dev": {
        "psr-4": {
            "HiTaqnia\\Haykal\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/haykal-core",
            "options": {
                "symlink": true,
                "versions": {
                    "hitaqnia/haykal-core": "1.0.0"
                }
            }
        },
        {
            "type": "path",
            "url": "packages/haykal-api",
            "options": {
                "symlink": true,
                "versions": {
                    "hitaqnia/haykal-api": "1.0.0"
                }
            }
        },
        {
            "type": "path",
            "url": "packages/haykal-filament",
            "options": {
                "symlink": true,
                "versions": {
                    "hitaqnia/haykal-filament": "1.0.0"
                }
            }
        },
        {
            "type": "path",
            "url": "packages/haykal",
            "options": {
                "symlink": true,
                "versions": {
                    "hitaqnia/haykal": "1.0.0"
                }
            }
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "format": "pint",
        "format:check": "pint --test"
    }
}