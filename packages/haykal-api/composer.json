{
    "name": "hitaqnia/haykal-api",
    "description": "Haykal API layer: ApiResponse, Scramble extensions, the /me endpoint, and conventions for Controllers / Requests / Resources.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "dedoc/scramble": "^0.13.20",
        "hitaqnia/haykal-core": "^1.0",
        "illuminate/contracts": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0",
        "spatie/laravel-query-builder": "^6.3"
    },
    "autoload": {
        "psr-4": {
            "HiTaqnia\\Haykal\\Api\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "HiTaqnia\\Haykal\\Api\\HaykalApiServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
