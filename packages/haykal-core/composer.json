{
    "name": "hitaqnia/haykal-core",
    "description": "Haykal shared utilities: Result pattern, tenancy primitives, phone-number value object, and two HTTP middlewares (user-locale + Spatie permissions-team bridge).",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/support": "^13.0",
        "spatie/laravel-permission": "^6.21"
    },
    "autoload": {
        "psr-4": {
            "HiTaqnia\\Haykal\\Core\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "HiTaqnia\\Haykal\\Core\\HaykalCoreServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
